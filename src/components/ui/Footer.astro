---
import { withBase } from '../../utils/url';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">JavaScript縁日</p>
      <p class="footer-tag">さわって、動かして、おぼえる。</p>
    </div>
    <nav aria-label="フッター">
      <ul class="footer-links">
        <li><a href={withBase('/courses/')}>コース一覧</a></li>
        <li><a href={withBase('/yatai/')}>屋台のこぼれ話</a></li>
        <li><a href={withBase('/about/')}>このサイトについて</a></li>
        <li><a href="https://github.com/langs-edu/js-edu">GitHub</a></li>
        <li><a href="https://kmizu.github.io/cs-edu-site/">姉妹サイト「言語の庭」</a></li>
        <li><a href="https://langs-edu.github.io/java-edu/">姉妹サイト「喫茶Java」</a></li>
        <li><a href="https://langs-edu.github.io/python-edu/">姉妹サイト「Pythonの湯」</a></li>
      </ul>
    </nav>
    <p class="footer-note">
      登録不要・広告なし・ずっと無料。<br />
      コード: MIT License ／ 文章: CC BY-SA 4.0
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-7);
    border-top: 1px solid var(--c-line);
    background: var(--c-paper-2);
    padding-block: var(--space-6);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    justify-content: space-between;
    align-items: start;
  }

  .footer-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
  }

  .footer-tag {
    color: var(--c-ink-2);
    font-size: 0.9rem;
    margin: var(--space-1) 0 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-4);
  }

  .footer-links a {
    color: var(--c-ink-2);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: var(--c-kon);
  }

  .footer-note {
    color: var(--c-ink-3);
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.8;
  }
</style>
