---
/**
 * 演習ブロック。ヒントは3段階の開示：
 *   ヒント1（考え方）→ ヒント2（かたち）→ こたえ（全文＋解説）
 * ヒントを開くことにペナルティはない。開くのは賢い学習行動。
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="exercise">
  <p class="exercise-title">
    <span class="exercise-mark">✎</span>
    {title}
  </p>
  <div class="exercise-body">
    <slot />
  </div>
</section>

<style>
  .exercise {
    border: 1px solid var(--c-line-strong);
    border-left: 3px solid var(--c-kon);
    border-radius: var(--radius-md);
    background: var(--c-paper);
    margin-block: var(--space-5);
    padding: var(--space-4);
  }

  .exercise-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    margin: 0 0 var(--space-3);
  }

  .exercise-mark {
    color: var(--c-kon);
    margin-right: 0.4em;
  }

  .exercise-body :global(details) {
    border: 1px dashed var(--c-line-strong);
    border-radius: var(--radius-sm);
    margin-block: var(--space-2);
    font-size: 0.95rem;
  }

  .exercise-body :global(summary) {
    cursor: pointer;
    padding: var(--space-2) var(--space-3);
    color: var(--c-ink-2);
    list-style: none;
  }

  .exercise-body :global(summary::-webkit-details-marker) {
    display: none;
  }

  .exercise-body :global(summary::before) {
    content: '＋ ';
    color: var(--c-kon);
  }

  .exercise-body :global(details[open] summary::before) {
    content: '− ';
  }

  .exercise-body :global(details > *:not(summary)) {
    padding-inline: var(--space-3);
  }

  .exercise-body :global(details[open]) {
    padding-bottom: var(--space-2);
  }
</style>
