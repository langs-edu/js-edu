---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { COURSES, courseByKey } from '../../../data/courses';
import { withBase } from '../../../utils/url';

export function getStaticPaths() {
  return COURSES.map((c) => ({ params: { course: c.key } }));
}

const { course: courseKey } = Astro.params;
const course = courseByKey(courseKey!)!;

const lessons = (await getCollection('lessons', (e) => e.data.course === course.key)).sort(
  (a, b) => a.data.order - b.data.order,
);
const comingSoon = course.total - lessons.length;
---

<BaseLayout title={course.title} description={course.description}>
  <main class="container">
    <header class="course-header">
      <p class="leaf-rule">コース {course.no}</p>
      <h1>{course.title}</h1>
      <p class="course-tagline">{course.tagline}</p>
      <p class="course-desc">{course.description}</p>
      {
        course.prerequisites && course.prerequisites.length > 0 && (
          <p class="course-pre">
            前提:{' '}
            {course.prerequisites
              .map((p) => `コース${courseByKey(p)?.no}「${courseByKey(p)?.title}」`)
              .join('・')}
            {course.recommended && course.recommended.length > 0 && (
              <>
                {' '}
                （推奨:{' '}
                {course.recommended
                  .map((p) => `コース${courseByKey(p)?.no}「${courseByKey(p)?.title}」`)
                  .join('・')}
                ）
              </>
            )}
          </p>
        )
      }
    </header>

    <ol class="lesson-list">
      {
        lessons.map((l) => (
          <li>
            <a
              class="lesson-item"
              href={withBase(`/courses/${course.key}/${l.id.split('/')[1]}/`)}
              data-lesson-id={l.id}
            >
              <span class="lesson-item-no">{String(l.data.order).padStart(2, '0')}</span>
              <span class="lesson-item-main">
                <span class="lesson-item-title">{l.data.title}</span>
                <span class="lesson-item-desc">{l.data.description}</span>
              </span>
              <svg class="lesson-item-lantern" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  class="lantern-outline"
                  d="M9 4.5h6M12 4.5v2M7 8.5c0-1.7 2.2-2 5-2s5 .3 5 2v7c0 1.7-2.2 2-5 2s-5-.3-5-2v-7z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linejoin="round"
                  stroke-linecap="round"
                />
                <path class="lantern-band" d="M7.3 12h9.4" fill="none" stroke="currentColor" stroke-width="1.3" />
                <path class="lantern-tassel" d="M12 17.5v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                <path
                  class="lantern-glow"
                  d="M4.5 9c-.6.6-.6 1.4 0 2M19.5 9c.6.6.6 1.4 0 2M4.5 15c-.6-.6-.6-1.4 0-2M19.5 15c.6-.6.6-1.4 0-2"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"
                />
              </svg>
            </a>
          </li>
        ))
      }
      {
        comingSoon > 0 && (
          <li class="lesson-item lesson-item-soon">
            <span class="lesson-item-no">…</span>
            <span class="lesson-item-main">
              <span class="lesson-item-title">のこり {comingSoon} レッスンは、これから仕込みます</span>
            </span>
          </li>
        )
      }
    </ol>
  </main>
</BaseLayout>

<script>
  try {
    const raw = localStorage.getItem('ennichi:progress:v1');
    if (raw) {
      const data = JSON.parse(raw) as { lessons?: Record<string, { done?: boolean }> };
      for (const a of document.querySelectorAll<HTMLAnchorElement>('[data-lesson-id]')) {
        if (data.lessons?.[a.dataset.lessonId!]?.done) a.classList.add('is-done');
      }
    }
  } catch {
    /* noop */
  }
</script>

<style>
  .course-header {
    padding-block: var(--space-6) var(--space-5);
    max-width: var(--measure);
  }

  .course-tagline {
    font-family: var(--font-display);
    color: var(--c-ink-2);
    font-size: 1.1rem;
    margin-top: var(--space-3);
  }

  .course-desc {
    color: var(--c-ink-2);
    line-height: 2;
  }

  .course-pre {
    color: var(--c-ink-3);
    font-size: 0.85rem;
  }

  .lesson-list {
    list-style: none;
    margin: 0 0 var(--space-7);
    padding: 0;
    max-width: 50rem;
    display: grid;
    gap: var(--space-2);
  }

  .lesson-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid var(--c-line-strong);
    border-radius: var(--radius-md);
    background: var(--c-paper);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    color: var(--c-ink);
    transition:
      transform var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) ease;
  }

  a.lesson-item:hover {
    transform: translateX(4px);
    border-color: var(--c-kon);
  }

  .lesson-item-no {
    font-family: var(--font-code);
    color: var(--c-ink-3);
    font-size: 0.9rem;
  }

  .lesson-item-main {
    display: grid;
    gap: 0.15em;
    min-width: 0;
    flex: 1;
  }

  .lesson-item-title {
    font-weight: 600;
  }

  .lesson-item-desc {
    font-size: 0.85rem;
    color: var(--c-ink-3);
    line-height: 1.7;
  }

  .lesson-item-lantern {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--c-line-strong);
  }

  .lesson-item-lantern .lantern-glow {
    display: none;
  }

  :global(.lesson-item.is-done) .lesson-item-lantern {
    color: var(--c-aka);
  }

  :global(.lesson-item.is-done) .lesson-item-lantern .lantern-glow {
    display: block;
  }

  .lesson-item-soon {
    border-style: dashed;
    opacity: 0.7;
  }
</style>
