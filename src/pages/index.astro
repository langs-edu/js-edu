---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { COURSES, courseByKey } from '../data/courses';
import { withBase } from '../utils/url';

const lessons = await getCollection('lessons');
const lessonCount = (key: string) => lessons.filter((l) => l.data.course === key).length;
const openCourses = COURSES.filter((c) => lessonCount(c.key) > 0);
const upcomingCourses = COURSES.filter((c) => lessonCount(c.key) === 0);
const KAZU = ['ひとつ', 'ふたつ', 'みっつ', 'よっつ', 'いつつ', 'むっつ'];
const courseCountWord = KAZU[openCourses.length - 1] ?? `${openCourses.length}つ`;

const firstLessonHref = withBase('/courses/hajimete/01/');
---

<BaseLayout title="JavaScript縁日">
  <main>
    <!-- ファーストビュー -->
    <section class="hero container">
      <div class="hero-text">
        <p class="leaf-rule">JavaScript縁日</p>
        <h1>さわって、<br class="sp-only" />動かして、おぼえる。</h1>
        <p class="hero-lead rise rise-2">
          登録不要、ずっと無料。インストールは要りません——このページの中に、書き換えて動かせる遊び場（プレイグラウンド）があります。JavaScriptは、ブラウザの言語だからです。
        </p>
      </div>
      <div class="hero-cta rise rise-3">
        <a class="btn btn-primary" href={firstLessonHref}>ここから、はじめる</a>
        <a class="btn btn-ghost" href={withBase('/courses/')}>コース一覧を見る</a>
      </div>
    </section>

    <!-- 4つの約束 -->
    <section class="promises">
      <div class="container">
        <ul class="promise-list">
          <li>
            <h2>インストール不要の遊び場</h2>
            <p>
              全レッスンに、その場で書き換えて実行できるプレイグラウンドを埋め込んでいます。読むだけで終わりません。押して、動かして、確かめてください。
            </p>
          </li>
          <li>
            <h2>登録不要・無料・広告なし</h2>
            <p>アカウントも、メールアドレスも、お金もいりません。ブラウザがあれば、それで全部です。</p>
          </li>
          <li>
            <h2>モダンJavaScriptが前提</h2>
            <p>
              let/const・テンプレートリテラル・アロー関数・class を、最初から自然な書き方として使います。古い書き方は「読めるとよい知識」として、区別してあつかいます。
            </p>
          </li>
          <li>
            <h2>コードはCIで検証済み</h2>
            <p>
              サンプルコードとプレイグラウンドの初期コードは、CIで<code>Node.js 22</code>により実行検証しています。ブラウザ専用（DOM）の例と意図的なエラー例は検証対象外で、実物の動作を確認して掲載しています。
            </p>
          </li>
        </ul>
      </div>
    </section>

    <!-- コース -->
    <section class="courses container">
      <p class="leaf-rule">出店</p>
      <h2 class="section-title">
        {upcomingCourses.length > 0 ? `${courseCountWord}のコースと、その先` : `${courseCountWord}のコース`}
      </h2>
      <div class="course-cards">
        {
          openCourses.map((c) => (
            <a class="course-card" href={withBase(`/courses/${c.key}/`)}>
              <span class="course-no">コース {c.no}</span>
              <h3>{c.title}</h3>
              <p>{c.tagline}。{c.description.split('。')[0]}。</p>
              <span class="course-meta">
                全{c.total}レッスン ・{' '}
                {c.prerequisites && c.prerequisites.length > 0
                  ? `コース${c.prerequisites.map((p) => courseByKey(p)?.no).join('・')}のつづき`
                  : '経験ゼロから'}
              </span>
            </a>
          ))
        }
        {
          upcomingCourses.length > 0 && (
            <div class="course-card course-card-soon" aria-hidden="true">
              <span class="course-no">仕込み中のコース</span>
              <h3>{upcomingCourses.map((c) => c.title.split(' — ')[0]).join(' ／ ')}</h3>
              <p>屋台は、すこしずつ増えていきます。</p>
            </div>
          )
        }
      </div>
    </section>

    <!-- 思想 -->
    <section class="philosophy">
      <div class="container philosophy-inner">
        <span class="tategaki philosophy-label" aria-hidden="true">この縁日の考え</span>
        <div class="prose">
          <h2>JavaScriptは、いま開いているこのページの中で動く言語です。</h2>
          <p>
            だからこの縁日では、あとで壊れるたとえを使いません。難しいことは隠さず、「いまは呪文のままでかまいません」と正直に保留を宣言しながら、押して、動かして、確かめてもらいます。
          </p>
          <p>
            エラーは失敗ではなく、誠実な読み手からの返事です。でもJavaScriptは、止まって教えてくれるとは限らない読み手でもあります——undefinedやNaNが黙って流れていくことも、隠さずお伝えします。
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq container">
      <p class="leaf-rule">よくある質問</p>
      <dl class="faq-list">
        <div>
          <dt>本当に無料ですか？</dt>
          <dd>無料です。広告もありません。このサイトはオープンソースで、教材はすべて公開されています。</dd>
        </div>
        <div>
          <dt>プログラミングの経験がなくても大丈夫ですか？</dt>
          <dd>
            はい。コース1「はじめてのJavaScript」は、プログラミング完全初心者を対象に書かれています。
          </dd>
        </div>
        <div>
          <dt>何を用意すればいいですか？</dt>
          <dd>
            ブラウザだけです。インストールは一切不要——このページを開いた時点で、もう準備は終わっています。
          </dd>
        </div>
      </dl>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-5);
    display: grid;
    gap: var(--space-4);
    max-width: 46rem;
  }

  .hero-lead {
    color: var(--c-ink-2);
    font-size: 1.05rem;
    margin: var(--space-3) 0 0;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .sp-only {
    display: none;
  }

  @media (max-width: 480px) {
    .sp-only {
      display: inline;
    }
  }

  .promises {
    background: var(--c-paper-2);
    border-block: 1px solid var(--c-line);
    padding-block: var(--space-6);
  }

  .promise-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-5);
  }

  .promise-list h2 {
    font-size: 1.15rem;
    margin-bottom: var(--space-2);
  }

  .promise-list p {
    color: var(--c-ink-2);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.9;
  }

  .courses {
    padding-block: var(--space-6);
  }

  .section-title {
    margin-block: var(--space-2) var(--space-5);
  }

  .course-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-4);
  }

  .course-card {
    display: block;
    border: 1px solid var(--c-line-strong);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    background: var(--c-paper);
    text-decoration: none;
    color: var(--c-ink);
    box-shadow: var(--shadow-card);
    transition:
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .course-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
  }

  .course-no {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: var(--tracking-wide);
    color: var(--c-kon);
  }

  .course-card h3 {
    margin-block: var(--space-2);
  }

  .course-card p {
    color: var(--c-ink-2);
    font-size: 0.92rem;
    line-height: 1.9;
    margin: 0 0 var(--space-3);
  }

  .course-meta {
    font-size: 0.8rem;
    color: var(--c-ink-3);
  }

  .course-card-soon {
    border-style: dashed;
    box-shadow: none;
  }

  .philosophy {
    background: var(--c-paper-2);
    border-block: 1px solid var(--c-line);
    padding-block: var(--space-6);
  }

  .philosophy-inner {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .philosophy-label {
    color: var(--c-kon);
    font-size: 0.9rem;
    border-right: 1px solid var(--c-line-strong);
    padding-right: var(--space-2);
    min-height: 9em;
  }

  .philosophy h2 {
    margin-bottom: var(--space-3);
  }

  .philosophy p {
    color: var(--c-ink-2);
    line-height: 2.1;
  }

  @media (max-width: 640px) {
    .philosophy-label {
      display: none;
    }
  }

  .faq {
    padding-block: var(--space-6) var(--space-4);
  }

  .faq-list {
    margin: var(--space-4) 0 0;
    display: grid;
    gap: var(--space-4);
    max-width: var(--measure);
  }

  .faq-list dt {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-1);
  }

  .faq-list dd {
    margin: 0;
    color: var(--c-ink-2);
    line-height: 1.9;
  }
</style>
